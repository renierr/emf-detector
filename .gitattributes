# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly handle common file types
*.dart text eol=lf
*.yaml text eol=lf
*.arb text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf

# Keep binary files as-is
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
